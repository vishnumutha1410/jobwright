# Copy to .env and fill in. Never commit your real .env.

# Where the Gmail OAuth client secret JSON lives (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=credentials.json
# Token cache created on first auth
GMAIL_TOKEN_PATH=token.json

# Email address the review drafts are addressed to (usually your own)
DRAFT_TO_EMAIL=you@example.com

# Path to the Excel tracker (created if missing)
TRACKER_PATH=Job_Search_Tracker.xlsx

# Only keep jobs posted within this many days
MAX_POSTING_AGE_DAYS=7
